# ============================================
# Demo Deployment Configuration
# For demo.chaptersdata.com
# ============================================

# Database — point to demo-specific Aurora instance or schema
DATABASE_URL=postgresql://demo_user:PASSWORD@demo-aurora-cluster.us-west-1.rds.amazonaws.com:5432/chapters_demo

# Auth — use separate Cognito pool for demo users
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-west-1_DEMO_POOL
NEXT_PUBLIC_COGNITO_CLIENT_ID=DEMO_CLIENT_ID
NEXT_PUBLIC_AWS_REGION=us-west-1

# QR
QR_REDIRECT_BASE_URL=https://demo.chaptersdata.com/r

# AI (can share or use separate keys)
ANTHROPIC_API_KEY=sk-ant-demo-key
SERPAPI_API_KEY=demo-serp-key
LEARNING_API_KEY=demo-learning-key

# S3
CHAPTERS_S3_BUCKET=retail-data-demo
CHAPTERS_ACCESS_KEY_ID=DEMO_KEY
CHAPTERS_SECRET_ACCESS_KEY=DEMO_SECRET
CHAPTERS_AWS_REGION=us-west-1

# Default org for learning pipeline
DEFAULT_ORG_ID=demo-org-001

# Amplify
AMPLIFY_APP_ID=DEMO_AMPLIFY_APP_ID
