# Environment Variables for chapters-data
# This file is the source of truth for all required environment variables.
# Copy this file to .env.local and fill in your values for local development.
# The pre-commit hook uses this file to generate amplify.yml build commands.
# The pre-push hook syncs values from .env.local to Amplify Console.

# Amplify Configuration (for automatic env var syncing)
# Find your App ID in AWS Amplify Console > App settings > General
AMPLIFY_APP_ID=

# Database
DATABASE_URL=

# AWS Cognito (NEXT_PUBLIC_ prefix makes them available client-side)
NEXT_PUBLIC_AWS_REGION=
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_IDENTITY_POOL_ID=

# AWS S3 Credentials
# Note: In Amplify Console, use S3_ prefix since AWS_ is reserved.
# The sync script maps: S3_ACCESS_KEY_ID -> AWS_ACCESS_KEY_ID, etc.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET_NAME=

# API Keys
ANTHROPIC_API_KEY=
SERPAPI_API_KEY=

# DynamoDB
DYNAMODB_QR_TABLE=
DYNAMODB_CLICKS_TABLE=

# QR Code
QR_REDIRECT_BASE_URL=

# Legacy Auth (if still used)
AUTH_ADMIN_HASH=
AUTH_ANALYST_HASH=

# Learning API (for Lambda-triggered autonomous learning)
LEARNING_API_KEY=

# Voyage AI (for semantic vector search over business insights)
VOYAGE_API_KEY=
