model BillingEvent {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  storefrontId   String?  @map("storefront_id")
  userId         String?  @map("user_id")
  eventType      String   @map("event_type")
  actionCategory String   @map("action_category")
  actionName     String   @map("action_name")
  baseCost       Decimal  @map("base_cost") @db.Decimal(10, 6)
  billedAmount   Decimal  @map("billed_amount") @db.Decimal(10, 4)
  multiplier     Decimal  @default(1) @db.Decimal(4, 2)
  billingMonth   String   @map("billing_month")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([orgId])
  @@index([billingMonth])
  @@index([eventType])
  @@index([createdAt])
  @@map("billing_events")
}

model SeoAudit {
  id          String         @id @default(uuid())
  domain      String
  status      String         @default("pending")
  createdAt   DateTime       @default(now()) @map("created_at")
  completedAt DateTime?      @map("completed_at")
  config      Json           @default("{}")
  progress    Json           @default("{}")
  summary     Json?
  error       String?
  pages       SeoAuditPage[]

  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("seo_audits")
}

model SeoAuditPage {
  id              String   @id @default(uuid())
  auditId         String   @map("audit_id")
  url             String
  statusCode      Int      @map("status_code")
  title           String?
  metaDescription String?  @map("meta_description")
  canonical       String?
  robots          String?
  headings        Json     @default("{}")
  images          Json     @default("{}")
  links           Json     @default("{}")
  performance     Json?
  issues          Json     @default("[]")
  crawledAt       DateTime @default(now()) @map("crawled_at")
  audit           SeoAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, url])
  @@index([auditId])
  @@map("seo_audit_pages")
}

model ResearchDocument {
  id             String            @id @default(uuid())
  filename       String
  category       String
  sourceUrl      String?           @map("source_url")
  summary        String
  relevanceScore String            @map("relevance_score")
  dateMentioned  DateTime?         @map("date_mentioned") @db.Date
  analyzedAt     DateTime          @map("analyzed_at")
  s3Key          String?           @map("s3_key")
  createdAt      DateTime          @default(now()) @map("created_at")
  findings       ResearchFinding[]

  @@index([category])
  @@index([analyzedAt])
  @@index([relevanceScore])
  @@map("research_documents")
}

model ResearchFinding {
  id                String           @id @default(uuid())
  documentId        String           @map("document_id")
  finding           String
  relevance         String
  category          String
  actionRequired    Boolean          @default(false) @map("action_required")
  recommendedAction String?          @map("recommended_action")
  createdAt         DateTime         @default(now()) @map("created_at")
  document          ResearchDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([category])
  @@index([relevance])
  @@map("research_findings")
}

model DomainTrustRegistry {
