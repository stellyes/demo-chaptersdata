}

model ExternalFeed {
  id             String             @id @default(uuid())
  name           String             @unique
  feedUrl        String             @map("feed_url")
  feedType       String             @default("rss") @map("feed_type")
  category       String
  isActive       Boolean            @default(true) @map("is_active")
  lastFetched    DateTime?          @map("last_fetched")
  lastSuccessful DateTime?          @map("last_successful")
  fetchFrequency Int                @default(86400) @map("fetch_frequency")
  itemsCount     Int                @default(0) @map("items_count")
  errorCount     Int                @default(0) @map("error_count")
  lastError      String?            @map("last_error")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  description    String?
  items          ExternalFeedItem[]

  @@index([category])
  @@index([isActive])
  @@map("external_feeds")
}

model ExternalFeedItem {
  id                 String       @id @default(uuid())
  feedId             String       @map("feed_id")
  guid               String       @unique
  title              String
  link               String
  publishedAt        DateTime     @map("published_at")
  summary            String?
  content            String?
  author             String?
  isProcessed        Boolean      @default(false) @map("is_processed")
  relevanceScore     Float?       @map("relevance_score")
  categories         String[]
  extractedInsights  String[]     @map("extracted_insights")
  createdAt          DateTime     @default(now()) @map("created_at")
  analyzedCategories String[]     @map("analyzed_categories")
  businessImpact     String?      @map("business_impact")
  keyEntities        String[]     @map("key_entities")
  feed               ExternalFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@index([feedId])
  @@index([publishedAt])
  @@index([isProcessed])
  @@index([relevanceScore])
  @@map("external_feed_items")
}

model RegulatoryEvent {
  id             String    @id @default(uuid())
  title          String
  description    String
  eventType      String    @map("event_type")
  eventDate      DateTime  @map("event_date")
  endDate        DateTime? @map("end_date")
  jurisdiction   String
  agency         String
  sourceUrl      String?   @map("source_url")
  sourceDocument String?   @map("source_document")
  impactLevel    String    @default("medium") @map("impact_level")
  impactAreas    String[]  @map("impact_areas")
  reminderSent   Boolean   @default(false) @map("reminder_sent")
  reminderDays   Int       @default(7) @map("reminder_days")
  isActive       Boolean   @default(true) @map("is_active")
  notes          String?
